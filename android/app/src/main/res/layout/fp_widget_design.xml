<?xml version="1.0" encoding="utf-8"?>
<!-- Design-Widget. RemoteViews-sicher: nur LinearLayout, TextView, TextClock.
     Der vertikale Strich ist eine schmale TextView mit Hintergrundfarbe –
     KEIN <View> (das war der RemoteViews-Übeltäter). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fp_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/fp_widget_design_bg"
    android:padding="12dp">

    <!-- Linke Spalte: Datum, darunter "+" und Sync -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextClock
            android:id="@+id/fp_widget_weekday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="EEEE"
            android:format24Hour="EEEE"
            android:textColor="#6B5B4D"
            android:textSize="12sp" />

        <TextClock
            android:id="@+id/fp_widget_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="d"
            android:format24Hour="d"
            android:textColor="#3E322A"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextClock
            android:id="@+id/fp_widget_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="MMMM"
            android:format24Hour="MMMM"
            android:textColor="#6B5B4D"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/fp_widget_add"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＋"
                android:textColor="#E8964F"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingEnd="16dp" />

            <TextView
                android:id="@+id/fp_widget_sync"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⟳"
                android:textColor="#E8964F"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Vertikaler Strich (schmale TextView mit Hintergrundfarbe) -->
    <TextView
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#33000000"
        android:text="" />

    <!-- Rechts: Terminliste -->
    <TextView
        android:id="@+id/fp_widget_body"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:textColor="#3E322A"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:ellipsize="end"
        android:text="–" />
</LinearLayout>
