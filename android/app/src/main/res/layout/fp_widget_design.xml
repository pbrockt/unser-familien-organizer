<?xml version="1.0" encoding="utf-8"?>
<!-- Design-Widget. RemoteViews-sicher: nur LinearLayout, TextView, TextClock.
     Vertikaler Strich = schmale TextView mit Hintergrundfarbe (kein <View>). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fp_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/fp_widget_design_bg"
    android:padding="12dp">

    <!-- Linke Spalte: Datum (mittig) oben, "+"/Sync unten links -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextClock
            android:id="@+id/fp_widget_weekday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="EEEE"
            android:format24Hour="EEEE"
            android:textColor="#6B5B4D"
            android:textSize="12sp" />

        <TextClock
            android:id="@+id/fp_widget_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="d"
            android:format24Hour="d"
            android:textColor="#3E322A"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextClock
            android:id="@+id/fp_widget_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="MMMM"
            android:format24Hour="MMMM"
            android:textColor="#6B5B4D"
            android:textSize="12sp" />

        <!-- Abstandshalter schiebt die Knöpfe nach unten -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/fp_widget_add"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＋"
                android:textColor="#99E8964F"
                android:textSize="17sp"
                android:textStyle="bold"
                android:paddingEnd="14dp" />

            <TextView
                android:id="@+id/fp_widget_sync"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⟳"
                android:textColor="#99E8964F"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Vertikaler Strich -->
    <TextView
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#33000000"
        android:text="" />

    <!-- Rechts: Terminliste -->
    <TextView
        android:id="@+id/fp_widget_body"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:textColor="#3E322A"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"
        android:ellipsize="end"
        android:text="–" />
</LinearLayout>
