<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fp_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fp_widget_bg"
    android:padding="16dp">

    <!-- Kopf: App-Icon + live Uhrzeit/Datum + Wetter-Chip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextClock
                android:id="@+id/fp_widget_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:textColor="@color/fp_orange"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextClock
                android:id="@+id/fp_widget_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="EEE, d. MMMM"
                android:format24Hour="EEE, d. MMMM"
                android:textColor="@color/fp_brown_soft"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/fp_widget_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/fp_widget_chip"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textColor="@color/fp_brown"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@color/fp_divider" />

    <!-- Heute / Morgen / Countdown -->
    <TextView
        android:id="@+id/fp_widget_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textColor="@color/fp_brown"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp"
        android:ellipsize="end"
        android:text="–" />
</LinearLayout>
