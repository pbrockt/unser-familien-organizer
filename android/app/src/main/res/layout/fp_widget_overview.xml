<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fp_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fp_widget_bg"
    android:padding="14dp">

    <!-- Kopf: live Uhrzeit/Datum + Wetter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextClock
                android:id="@+id/fp_widget_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:textColor="#E8964F"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextClock
                android:id="@+id/fp_widget_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="EEE, d. MMMM"
                android:format24Hour="EEE, d. MMMM"
                android:textColor="#6B5B4D"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/fp_widget_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#3E322A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#22000000" />

    <!-- Heute / Morgen / Countdown -->
    <TextView
        android:id="@+id/fp_widget_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textColor="#3E322A"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:ellipsize="end"
        android:text="–" />
</LinearLayout>
