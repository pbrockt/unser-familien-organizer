<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Für CalDAV-Sync mit Nextcloud (auch im Release-Build nötig!). -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Für lokale Erinnerungen (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Damit geplante Erinnerungen einen Neustart überleben. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- Für In-App-Update: heruntergeladenes APK installieren. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <!-- Damit der Hintergrund-Sync (Erinnerungen) nicht von der Akku-Optimierung
         abgewürgt wird – Nutzer kann die App ausnehmen. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <application
        android:label="Unser Familien-Organizer"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <!-- Flutters Auto-Deeplinking aus: Widget-URLs (familyplanner://…)
                 dürfen NICHT als Router-Seite interpretiert werden – wir
                 verarbeiten Widget-Klicks selbst in der AppShell. -->
            <meta-data
              android:name="flutter_deeplinking_enabled"
              android:value="false"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Plant geplante Erinnerungen nach einem Neustart neu ein. -->
        <receiver android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- Home-Screen-Widget: Anstehende Termine.
             exported=true, damit das System onUpdate beim Platzieren selbst
             aufruft (sonst bleibt das Widget auf dem System-Platzhalter). -->
        <receiver android:name=".NextEventsWidget" android:exported="true"
            android:label="Anstehende Termine">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/fp_widget_next"/>
        </receiver>
        <receiver android:name=".CountdownWidget" android:exported="true"
            android:label="Countdown">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/fp_widget_countdown"/>
        </receiver>
        <receiver android:name=".DesignWidget" android:exported="true"
            android:label="Termine (Design, mit + Knopf)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/fp_widget_design"/>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Damit url_launcher den Browser für die Releases-Seite öffnen kann. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
